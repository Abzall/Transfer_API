generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Appeal {
  id       String        @id @default(uuid())
  category String
  status   String
  message  String
  children AppealChild[]
}

model AppealChild {
  id        String @id @default(uuid())
  appealId  String
  childIin  String
  childName String
  appeal    Appeal @relation(fields: [appealId], references: [id])
}

model AthleteProfile {
  id          String       @id @default(uuid())
  iin         String       @unique
  enrollments Enrollment[]
}

model SportsCenterProgram {
  id             String       @id @default(uuid())
  sportsCenterId String
  sportType      String
  capacity       Int
  enrollments    Enrollment[]
}

model Enrollment {
  id               String              @id @default(uuid())
  athleteProfileId String
  sportsCenterId   String
  programId        String
  status           String
  athlete          AthleteProfile      @relation(fields: [athleteProfileId], references: [id])
  program          SportsCenterProgram @relation(fields: [programId], references: [id])
}